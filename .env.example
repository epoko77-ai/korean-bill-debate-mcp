ASSEMBLY_OPEN_API_KEY=
# Optional verified service-code overrides:
# ASSEMBLY_PLENARY_DATASET=nzbyfwhwaoanttzje
# ASSEMBLY_COMMITTEE_DATASET=ncwgseseafwbuheph
# ASSEMBLY_SUBCOMMITTEE_DATASET=VCONFSUBCCONFLIST

# Hosted OAuth deployment (generate values; never commit real secrets).
# The two credential secrets are Fernet keys; the internal secret must be an
# independent 32-512 byte printable ASCII value:
# KBD_REMOTE_TOKEN_SECRET=
# KBD_RESEARCH_CREDENTIAL_SECRET=
# KBD_INTERNAL_TASK_SECRET=
# Vercel Cron sends this independent secret to the bounded poll-mode recovery
# consumer. Use 32-512 printable ASCII bytes and never reuse an API key:
# CRON_SECRET=

# Production host protection. Replace the host when self-hosting; the three
# supported web MCP origins are also added defensively in hosted user-key mode.
# KASM_ALLOWED_HOSTS=korean-bill-debate-mcp.vercel.app
# KASM_ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com,https://chat.openai.com

# Durable hosted research requires a private Vercel Blob project connection.
# Vercel injects this value; leave it empty in local files and CI fixtures.
# BLOB_READ_WRITE_TOKEN=

# Keep the application and Vercel queue trigger topics identical.
# KBD_RESEARCH_QUEUE_TOPIC=kbd-research

# Only set this after publishing and verifying a complete corpus revision.
# KBD_RESEARCH_CORPUS_REVISION=

# Vercel supplies VERCEL_DEPLOYMENT_ID, VERCEL_URL, and the request OIDC
# identity when System Environment Variables and Secure Backend Access with
# OIDC are enabled. Do not define these values manually.
